<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <title>تصميم نادر مهيم</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      font-family: 'Cairo', Arial, sans-serif;
      direction: rtl;
      background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
      margin: 0;
    }
    .navbar-brand {
      font-weight: bold;
      font-size: 2rem;
      color: #1877f2 !important;
      letter-spacing: 2px;
    }
    .unique-title {
      font-family: 'Cairo', Arial, sans-serif;
      font-size: 3rem;
      font-weight: bold;
      color: #ff6600;
      margin-top: 32px;
      margin-bottom: 24px;
      letter-spacing: 2px;
      text-shadow: 2px 2px 2px #fff9;
      text-align: center;
    }
    .section-card {
      background: #fff;
      border-radius: 15px;
      padding: 30px;
      box-shadow:-card:hover {
      box-shadow: 0 4px 25px #c6e2f7;
    }
    .service-icon {
      font-size: 2.5rem;
      color: #1877f2;
      margin-bottom: 10px;
      transition: transform .2s;
    }
    .service-icon:hover {
      color: #ff6600;
      transform: scale(1.2);
    }
    .gallery-img {
      width: 100%;
      height: 180px;
      object-fit: cover;
      border-radius: 10px;
      transition: transform .3s;
      cursor: pointer;
    }
    .gallery-img:hover {
      transform: scale(1.08);
      filter: brightness(1.25);
    }
    .team-img {
      border-radius: 50%;
      width: 110px;
      height: 110px;
      object-fit: cover;
      margin-bottom: 10px;
      box-shadow: 0 2px 8px #aaa;
      border: 5px solid #c3cfe2;
      transition: border-color .2s, transform .2s;
    }
    .team-img:hover {
      border-color: #ff6600;
      transform: scale(1.1);
    }
    .section-title {
      margin: 30px 0 20px;
      font-size: 2rem;
      font-weight: bold;
      color: #1877f2;
    }
    footer {
      background: #1877f2;
      color: #fff;
      padding: 25px 0;
      text-align: center;
      font-size: 18px;
      margin-top: 40px;
      letter-spacing: 1px;
    }
  </style>
</head>
<body>
  <!-- القائمة العلوية -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light sticky-top">
    <div class="container">
      <a class="navbar-brand" href="#">تصميم نادر مهيم</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link active" href="#home">الرئيسية</a></li>
          <li class="nav-item"><a class="nav-link" href="#services">الخدمات</a></li>
          <li class="nav-item"><a class="nav-link" href="#gallery">معرض الصور</a></li>
          <li class="nav-item"><a class="nav-link" href="#team">فريق العمل</a></li>
          <li class="nav-item"><a class="nav-link" href="#about">عن الموقع</a></li>
          <li class="nav-item"><a class="nav-link" href="#contact">اتصل بنا</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- الرئيسية -->
  <section id="home" class="container text-center mt-5">
    <div class="unique-title">تصميم نادر مهيم</div>
    <div class="section-card mx-auto" style="max-width:700px;">
      <p>مرحبًا بك في الموقع الذي يجمع بين التصميم النادر والتميز في تجربة المستخدم. هنا تجد كل ما تحتاج لتطوير مشروعك بشكل عصري وتفاعلي!</p>
      <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=400&q=80" class="img-fluid rounded" style="max-width:300px;" alt="صورة ترحيبية">
    </div>
  </section>

  <!-- الخدمات -->
  <section id="services" class="container">
    <h2 class="section-title">الخدمات</h2>
    <div class="row">
      <div class="col-md-4 mb-4">
        <div class="section-card text-center">
          <div class="service-icon"><i class="fa fa-laptop-code"></i></div>
          <h4>تطوير المواقع</h4>
          <p>مواقع ديناميكية تفاعلية بأحدث التقنيات، تناسب جميع الأجهزة.</p>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="section-card text-center">
          <div class="service-icon"><i class="fa fa-mobile-alt"></i></div>
          <h4>تطبيقات الجوال</h4>
          <p>تطبيقات Android وiOS حديثة ومبتكرة.</p>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="section-card text-center">
          <div class="service-icon"><i class="fa fa-paint-brush"></i></div>
          <h4>تصاميم فريدة</h4>
          <p>لوغوهات، هوية بصرية، واجهات مستخدم بجودة عالية.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- معرض الصور -->
  <section id="gallery" class="container">
    <h2 class="section-title">معرض الصور</h2>
    <div class="row">
      <div class="col-md-4 mb-3">
        <img src="https://images.unsplash.com/photo-1482062364825-616fd23b8fc1?auto=format&fit=crop&w=400&q=80" class="gallery-img" alt="معرض 1">
      </div>
      <div class="col-md-4 mb-3">
        <img src="https://images.unsplash.com/photo-1461749281690-4f7fdc59a75b?auto=format&fit=crop&w=400&q=80" class="gallery-img" alt="معرض 2">
      </div>
      <div class="col-md-4 mb-3">
        <img src="https://images.unsplash.com/photo-1519125323398-675f0ddb6308?auto=format&fit=crop&w=400&q=80" class="gallery-img" alt="معرض 3">
      </div>
    </div>
  </section>

  <!-- فريق العمل -->
  <section id="team" class="container">
    <h2 class="section-title">فريق العمل</h2>
    <div class="row text-center">
      <div class="col-md-3 col-sm-6 mb-4">
        <img src="https://randomuser.me/api/portraits/men/32.jpg" class="team-img" alt="عضو الفريق">
        <h5>نادر مهيم</h5>
        <small>مصمم ومطور رئيسي</small>
      </div>
      <div class="col-md-3 col-sm-6 mb-4">
        <img src="https://randomuser.me/api/portraits/women/44.jpg" class="team-img" alt="عضو الفريق">
        <h5>سارة محمد</h5>
        <small>مديرة مشاريع</small>
      </div>
      <div class="col-md-3 col-sm-6 mb-4">
        <img src="https://randomuser/api/portraits/men/54.jpg" class="team-img" alt="عضو الفريق">
        <h5>خالد حسن</h5>
        <small>مطور تطبيقات</small>
      </div>
      <div class="col-md-3 col-sm-6 mb-4">
        <img src="https://randomuser.me/api/portraits/women/66.jpg" class="team-img" alt="عضو الفريق">
        <h5>ريم علي</h5>
        <small>مبدعة تصميم</small>
      </div>
    </div>
  </section>

  <!-- عن الموقع -->
  <section id="about" class="container">
    <h2 class="section-title">عن الموقع</h2>
    <div class="section-card">
      <p>تصميم نادر مهيم يجمع بين البساطة والحداثة مع أفضل الممارسات في تجربة المستخدم. الموقع يلبي جميع الاحتياجات ويعمل على كل الأجهزة بمرونة وسرعة.</p>
    </div>
  </section>

  <!-- اتصل بنا -->
  <section id="contact" class="container mb-4">
    <h2 class="section-title">اتصل بنا</h2>
    <div class="section-card mx-auto" style="max-width: 600px;">
      <form id="contactForm">
        <div class="mb-3">
          <label class="form-label">الاسم</label>
          <input type="text" class="form-control" required>
        </div>
        <div class="mb-3">
          <label class="form-label">البريد الإلكتروني</label>
          <input type="email" class="form-control" required>
        </div>
        <div class="mb-3">
          <label class="form-label">رسالتك</label>
          <textarea class="form-control" rows="4" required></textarea>
        </div>
        <button type="submit" class="btn btn-warning">إرسال</button>
      </form>
      <div id="contactMsg"></div>
    </div>
  </section>

  <!-- تذييل الموقع -->
  <footer>
    جميع الحقوق محفوظة &copy; تصميم نادر مهيم 2026
  </footer>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // تنقل سلس للروابط
    document.querySelectorAll('.nav-link').forEach(function(link){
      link.addEventListener('click', function(e){
        e.preventDefault();
        let target = this.getAttribute('href');
        document.querySelector(target).scrollIntoView({behavior: 'smooth'});
        // تفعيل الرابط الحالي
        document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
        this.classList.add('active');
      });
    });
    // رسالة الإرسال
    document.getElementById('contactForm').addEventListener('submit', function(e){
      e.preventDefault();
      document.getElementById('contactMsg').innerHTML = "<div class='alert alert-success'>تم إرسال رسالتك بنجاح!</div>";
      this.reset();
    });
  </script>
</body>
</html
